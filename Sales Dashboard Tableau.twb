      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Product-Sales-Region)' name='federated.07sofg31wnpohc1fu0dyr1kxcyow' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='2024' caption='Year Selected' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2024'>
              <calculation class='tableau' formula='2024' />
              <aliases>
                <alias key='2024' value='2024' />
                <alias key='2025' value='2025' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.07sofg31wnpohc1fu0dyr1kxcyow'>
            <column caption='CY Profit' datatype='real' name='[Calculation_287385966275391501]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN&#13;&#10;[Calculation_287385966275928078] - [ShippingCost]&#13;&#10;END' />
            </column>
            <column caption='CY REVENUE' datatype='real' name='[Calculation_287385966275928078]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN&#13;&#10;    [Quantity] * [UnitPrice] * (1 - [Discount])&#13;&#10;END' />
            </column>
            <column caption='PY Profit' datatype='real' name='[Calculation_287385966276476944]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF INT(YEAR([OrderDate])) = INT([Parameters].[Parameter 1]) - 1&#13;&#10;THEN&#13;&#10;    ([Quantity] * [UnitPrice] * (1 - [Discount])) - [ShippingCost]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Total Profit/LOSS' datatype='real' name='[Calculation_287385966277017618]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_287385966275391501])-[Calculation_287385966276476944]' />
            </column>
            <column caption='CY Sales' datatype='real' name='[Calculation_318911161145823234]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;THEN [TotalPrice]&#13;&#10;END' />
            </column>
            <column caption='PY Sales' datatype='real' name='[Calculation_318911161146077187]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([OrderDate]) = [Parameters].[Parameter 1] - 1&#13;&#10;THEN [TotalPrice]&#13;&#10;END' />
            </column>
            <column datatype='real' name='[Discount]' role='measure' type='quantitative' />
            <column caption='Order Date' datatype='date' name='[OrderDate]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Product]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Quantity]' role='measure' type='quantitative' />
            <column caption='Shipping Cost' datatype='real' name='[ShippingCost]' role='measure' type='quantitative' />
            <column caption='Total Price' datatype='real' name='[TotalPrice]' role='measure' type='quantitative' />
