              <calculation class='tableau' formula='IF SUM([Calculation_318911161145823234]) = WINDOW_MAX(SUM([Calculation_318911161145823234]))&#13;&#10;OR SUM([Calculation_318911161145823234]) = WINDOW_MIN(SUM([Calculation_318911161145823234]))&#13;&#10;THEN SUM([Calculation_318911161145823234])&#13;&#10;END'>
