      <column caption='KPI Display' datatype='string' name='[Calculation_318911161147334663]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;$&quot; + STR(ROUND(SUM([Calculation_318911161145823234]) / 1000))&#13;&#10;+&#13;&#10;&quot;K | &quot;&#13;&#10;+&#13;&#10;IF [Calculation_318911161146511366] &gt; 0 THEN &quot;▲ &quot; ELSE &quot;▼ &quot; END&#13;&#10;+&#13;&#10;STR(ROUND(ROUND([Calculation_318911161146511366]) * 100, 1))&#13;&#10;+&#13;&#10;&quot;%&quot;' />
      </column>
