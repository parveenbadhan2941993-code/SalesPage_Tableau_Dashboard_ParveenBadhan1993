      <column caption='Discount &amp; Shipping Display' datatype='string' name='[Calculation_318911161187409966]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;(&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] AND [Discount] &gt; 0 THEN [TotalPrice] END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [TotalPrice] END)&#13;&#10;) &gt; 0.5&#13;&#10;OR&#13;&#10;(&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [ShippingCost] END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [TotalPrice] END)&#13;&#10;) &gt; 0.15&#13;&#10;THEN &quot;🚨 &quot;&#13;&#10;ELSE &quot;▲ &quot;&#13;&#10;END&#13;&#10;+&#13;&#10;STR(&#13;&#10;ROUND(&#13;&#10;(&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] AND [Discount] &gt; 0 THEN [TotalPrice] END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [TotalPrice] END)&#13;&#10;)*100)&#13;&#10;)&#13;&#10;+&#13;&#10;&quot;% | &quot;&#13;&#10;+&#13;&#10;STR(&#13;&#10;ROUND(&#13;&#10;(&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [ShippingCost] END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [TotalPrice] END)&#13;&#10;)*100)&#13;&#10;)&#13;&#10;+&#13;&#10;&quot;% &quot;&#13;&#10;+&#13;&#10;IF &#13;&#10;(&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] AND [Discount] &gt; 0 THEN [TotalPrice] END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [TotalPrice] END)&#13;&#10;) &gt; 0.5&#13;&#10;OR&#13;&#10;(&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [ShippingCost] END)&#13;&#10;/&#13;&#10;SUM(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [TotalPrice] END)&#13;&#10;) &gt; 0.15&#13;&#10;THEN &quot;| HIGH RISK&quot;&#13;&#10;ELSE &quot;| HEALTHY&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Discount' datatype='real' name='[Calculation_318911161187962927]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;AND [Discount] &gt; 0&#13;&#10;THEN&#13;&#10;([TotalPrice] / (1 - [Discount])) - [TotalPrice]&#13;&#10;END&#13;&#10;)' />
