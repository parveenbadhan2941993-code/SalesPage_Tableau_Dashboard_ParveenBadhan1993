      <aliases enabled='yes' />
      <column caption='Cumulative %' datatype='real' name='[Calculation_1435522394420031510]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([TotalPrice]))&#13;&#10;/&#13;&#10;TOTAL(SUM([TotalPrice]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Running Sum' datatype='real' name='[Calculation_1435522394420592663]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([TotalPrice]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sort_P' datatype='real' name='[Calculation_1435522394420879384]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Product] : SUM([TotalPrice]) }' />
      </column>
      <column caption='First order month' datatype='datetime' name='[Calculation_1435522394435444765]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, { FIXED [CustomerName] : MIN([OrderDate]) })' />
      </column>
      <column caption='Order Month' datatype='datetime' name='[Calculation_1435522394435616798]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [OrderDate])' />
      </column>
      <column caption='Customers' datatype='integer' name='[Calculation_1435522394436386847]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerName])' />
      </column>
      <column caption='Customer loyality' datatype='string' name='[Calculation_1435522394444378144]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE { FIXED [CustomerName] : COUNTD([OrderID]) }&#13;&#10;&#13;&#10;WHEN 1 THEN &quot;1 Order (New - No Loyalty)&quot;&#13;&#10;WHEN 2 THEN &quot;2 Orders (Low Loyalty)&quot;&#13;&#10;WHEN 3 THEN &quot;3 Orders (Low Loyalty)&quot;&#13;&#10;WHEN 4 THEN &quot;4 Orders (Medium Loyalty)&quot;&#13;&#10;WHEN 5 THEN &quot;5 Orders (Medium Loyalty)&quot;&#13;&#10;WHEN 6 THEN &quot;6 Orders (High Loyalty)&quot;&#13;&#10;WHEN 7 THEN &quot;7 Orders (High Loyalty)&quot;&#13;&#10;WHEN 8 THEN &quot;8+ Orders (Very High Loyalty)&quot;&#13;&#10;&#13;&#10;ELSE &quot;8+ Orders (Very High Loyalty)&quot;&#13;&#10;END' />
      </column>
      <column caption='Order Count per Customer' datatype='integer' name='[Calculation_1435522394448162849]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [CustomerName] : COUNTD([OrderID]) }' />
      </column>
      <column caption='Region Manager Sales' datatype='real' name='[Calculation_1435522394475659302]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [RegionManager] :&#13;&#10;    SUM(&#13;&#10;        IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;        THEN [TotalPrice]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Delivery Days' datatype='integer' name='[Calculation_1505609665110089728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&#13;&#10;&apos;day&apos;,&#13;&#10;[OrderDate],&#13;&#10;[DeliveryDate]&#13;&#10;)' />
      </column>
      <column caption='Avg Delivery Days' datatype='real' name='[Calculation_1505609665110159361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1505609665110089728])' />
      </column>
      <column caption='Net Revenue' datatype='real' name='[Calculation_1505609665110360066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPrice])&#13;&#10;-&#13;&#10;SUM([Discount])&#13;&#10;-&#13;&#10;SUM([ShippingCost])' />
      </column>
      <column caption='Revenue Per Customer CY' datatype='real' name='[Calculation_1542201411017289729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;    THEN [TotalPrice]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD(&#13;&#10;    IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;    THEN [CustomerName]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_1542201411017887746]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([OrderDate]) [Selected Year] THEN&#13;&#10;SUM([TotalPrice]) / COUNTD([CustomerName])&#13;&#10;END' />
      </column>
      <column caption='PY Revenue per Customer' datatype='real' name='[Calculation_1542201411019075587]' role='measure' type='quantitative'>
