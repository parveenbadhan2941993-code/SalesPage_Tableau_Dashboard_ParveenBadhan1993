              <calculation class='tableau' formula='SUM(&#13;&#10;    IF YEAR([OrderDate]) = [Parameters].[Parameter 1] - 1&#13;&#10;    THEN [TotalPrice]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD(&#13;&#10;    IF YEAR([OrderDate]) = [Parameters].[Parameter 1] - 1&#13;&#10;    THEN [CustomerName]&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column caption='Variance' datatype='real' name='[Calculation_1542201411019390980]' role='measure' type='quantitative'>
