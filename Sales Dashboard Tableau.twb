      <column caption='Quarter' datatype='datetime' name='[Calculation_318911161158127628]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;quarter&apos;,[OrderDate])' />
      </column>
      <column caption='Order KPI' datatype='string' name='[Calculation_318911161163935763]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(&#13;&#10;COUNT(&#13;&#10;IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;THEN [OrderID]&#13;&#10;END&#13;&#10;)&#13;&#10;)&#13;&#10;+&#13;&#10;&quot; | &quot;&#13;&#10;+&#13;&#10;IF &#13;&#10;(&#13;&#10;(&#13;&#10;COUNT(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [OrderID] END)&#13;&#10;-&#13;&#10;COUNT(IF YEAR([OrderDate]) = [Parameters].[Parameter 1]-1 THEN [OrderID] END)&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(IF YEAR([OrderDate]) = [Parameters].[Parameter 1]-1 THEN [OrderID] END)&#13;&#10;) &gt; 0&#13;&#10;THEN &quot;▲ &quot; ELSE &quot;▼ &quot; END&#13;&#10;+&#13;&#10;STR(&#13;&#10;ROUND(&#13;&#10;(&#13;&#10;(&#13;&#10;COUNT(IF YEAR([OrderDate]) = [Parameters].[Parameter 1] THEN [OrderID] END)&#13;&#10;-&#13;&#10;COUNT(IF YEAR([OrderDate]) = [Parameters].[Parameter 1]-1 THEN [OrderID] END)&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT(IF YEAR([OrderDate]) = [Parameters].[Parameter 1]-1 THEN [OrderID] END)&#13;&#10;)&#13;&#10;*100)&#13;&#10;)&#13;&#10;+&#13;&#10;&quot;%&quot;' />
