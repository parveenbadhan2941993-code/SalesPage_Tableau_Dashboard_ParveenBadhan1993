    <worksheet name='Region and salesperson'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='false' fontalignment='1' fontname='Tableau Semibold' fontsize='10'>Sales by Region &amp; Salesperson</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Product-Sales-Region)' name='federated.07sofg31wnpohc1fu0dyr1kxcyow' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='2024' caption='Year Selected' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2024'>
              <calculation class='tableau' formula='2024' />
              <aliases>
                <alias key='2024' value='2024' />
                <alias key='2025' value='2025' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.07sofg31wnpohc1fu0dyr1kxcyow'>
            <column caption='Region Manager Sales' datatype='real' name='[Calculation_1435522394475659302]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [RegionManager] :&#13;&#10;    SUM(&#13;&#10;        IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;        THEN [TotalPrice]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Year Selected Profit' datatype='integer' name='[Calculation_287385966483443762]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ATTR(&#13;&#10;IF YEAR([Date]) = [Parameters].[Parameter 1]&#13;&#10;THEN [Parameters].[Parameter 1]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Total Sales' datatype='real' name='[Calculation_318911161151209483]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([TotalPrice])' />
            </column>
            <column caption='Total Orders' datatype='integer' name='[Calculation_318911161164623892]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([OrderID])' />
            </column>
            <column caption='Total Discount' datatype='real' name='[Calculation_318911161187962927]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;AND [Discount] &gt; 0&#13;&#10;THEN&#13;&#10;([TotalPrice] / (1 - [Discount])) - [TotalPrice]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Total Shipping Amount ' datatype='real' name='[Calculation_318911161188679728]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;AND [Discount] &gt; 0&#13;&#10;THEN&#13;&#10;[ShippingCost]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column datatype='date' name='[Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Discount]' role='measure' type='quantitative' />
            <column caption='Order Date' datatype='date' name='[OrderDate]' role='dimension' type='ordinal' />
            <column caption='Order ID' datatype='string' name='[OrderID]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Quantity]' role='measure' type='quantitative' />
            <column caption='Region Manager' datatype='string' name='[RegionManager]' role='dimension' type='nominal' />
            <column datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column caption='Shipping Cost' datatype='real' name='[ShippingCost]' role='measure' type='quantitative' />
            <column caption='Total Price' datatype='real' name='[TotalPrice]' role='measure' type='quantitative' />
