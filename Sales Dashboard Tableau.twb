      </column>
      <column caption='Return Display' datatype='string' name='[Calculation_318911161179078694]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(&#13;&#10;COUNT(IF [Returned]=1 THEN [OrderID] END)&#13;&#10;/&#13;&#10;COUNT([OrderID])&#13;&#10;*100))&#13;&#10;+&#13;&#10;&quot;% | &quot;&#13;&#10;+&#13;&#10;IF (&#13;&#10;COUNT(IF [Returned]=1 THEN [OrderID] END)&#13;&#10;/&#13;&#10;COUNT([OrderID])&#13;&#10;) &gt; 0.05 THEN &quot;❗ High Returns&quot; ELSE &quot;✓ Healthy&quot; END' />
      </column>
