      </column>
      <column caption='Quant. KPI Display' datatype='string' name='[Calculation_318911161173377055]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(&#13;&#10;SUM(&#13;&#10;IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;THEN [Quantity]&#13;&#10;END&#13;&#10;)&#13;&#10;)&#13;&#10;+&#13;&#10;&quot; | &quot;&#13;&#10;+&#13;&#10;IF [Calculation_318911161173225502] &gt; 0 THEN &quot;▲ &quot; ELSE &quot;▼ &quot; END&#13;&#10;+&#13;&#10;STR(ROUND([Calculation_318911161173225502]*100))&#13;&#10;+&#13;&#10;&quot;%&quot;' />
      </column>
      <column caption='Return orders' datatype='integer' name='[Calculation_318911161178230820]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF YEAR([OrderDate]) = [Parameters].[Parameter 1]&#13;&#10;AND [Returned] = 1&#13;&#10;THEN [OrderID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Return Rate%' datatype='real' name='[Calculation_318911161178890277]' role='measure' type='quantitative'>
