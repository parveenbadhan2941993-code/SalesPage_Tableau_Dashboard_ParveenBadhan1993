              <calculation class='tableau' formula='{[Calculation_318911161187229740]}' />
            </column>
            <column caption='{[Net Revenue]}' datatype='real' name='[Calculation_287385966170562566]' role='measure' type='quantitative' user:unnamed='CAL KPi'>
              <calculation class='tableau' formula='{[Calculation_1505609665110360066]}' />
            </column>
            <column caption='Return Rate%' datatype='real' name='[Calculation_318911161178890277]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Returned] = 1&#13;&#10;THEN [OrderID]&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([OrderID])' />
